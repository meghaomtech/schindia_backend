{
  "family": "shichida-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/shichida-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/shichida-ecs-task-role",
  "volumes": [
    {
      "name": "shichida-efs-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "${EFS_FILESYSTEM_ID}",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "${EFS_ACCESS_POINT_ID}",
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "shichida-backend",
      "image": "${AWS_ACCOUNT_ID}.dkr.ecr.ap-south-1.amazonaws.com/shichida-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DJANGO_ENV",           "value": "production" },
        { "name": "DJANGO_DEBUG",         "value": "False" },
        { "name": "DJANGO_DB_PATH",       "value": "/data/db.sqlite3" },
        { "name": "DYNAMODB_REGION",      "value": "ap-south-1" },
        { "name": "AWS_REGION",           "value": "ap-south-1" },
        { "name": "DYNAMODB_INVOICES_TABLE", "value": "ShichidaInvoices" }
      ],
      "secrets": [
        {
          "name": "DJANGO_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:${AWS_ACCOUNT_ID}:secret:shichida/django-secret-key"
        },
        {
          "name": "ALLOWED_HOSTS",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:${AWS_ACCOUNT_ID}:secret:shichida/allowed-hosts"
        },
        {
          "name": "CORS_ALLOWED_ORIGINS",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:${AWS_ACCOUNT_ID}:secret:shichida/cors-origins"
        }
      ],
      "mountPoints": [
        {
          "containerPath": "/data",
          "sourceVolume": "shichida-efs-data",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/shichida-backend",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python manage.py check || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
