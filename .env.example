# ===========================================
# LOCAL DEVELOPMENT (SQLite - no AWS needed)
# ===========================================
DJANGO_ENV=local
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here

# ===========================================
# AWS Credentials
# ===========================================
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1

# ===========================================
# PRODUCTION Database (AWS RDS PostgreSQL)
# ===========================================
PROD_DB_NAME=shichida
PROD_DB_USER=shichida_admin
PROD_DB_PASSWORD=your-rds-password
PROD_DB_HOST=your-rds-endpoint.rds.amazonaws.com
PROD_DB_PORT=5432

# ===========================================
# AWS S3 (File Storage)
# ===========================================
AWS_STORAGE_BUCKET_NAME=shichida-uploads
AWS_S3_CUSTOM_DOMAIN=

# ===========================================
# AWS SES (Email)
# ===========================================
AWS_SES_SENDER=noreply@shichida.in

# ===========================================
# CORS
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
